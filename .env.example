# ─── tacos-aragon-api — Variables de entorno requeridas ──────────────────────
# Copia este archivo como .env (local) o define las vars en ecosystem.config.js
# NUNCA subas el archivo .env ni ecosystem.config.js con valores reales a git.

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Autenticación de la API (REQUERIDO) ───────────────────────────────────────
# Genera un token seguro: node -e "require('crypto').randomBytes(32).toString('hex')|xargs echo"
API_TOKEN=TU_TOKEN_SECRETO_AQUI

# ── CORS — Orígenes permitidos (separa múltiples con coma) ────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Loyverse POS (REQUERIDO) ──────────────────────────────────────────────────
LOYVERSE_TOKEN=TU_TOKEN_DE_LOYVERSE
LOYVERSE_STORE_ID=TU_STORE_ID_DE_LOYVERSE

# ── Google Gemini (transcripción de voz) ─────────────────────────────────────
GEMINI_KEY=TU_API_KEY_DE_GEMINI

# ── Anthropic (agente principal) (REQUERIDO) ─────────────────────────────────
ANTHROPIC_KEY=sk-ant-api03-XXXXXXXXXXXXXXXX

# ── Ruta al folder datos/ del bot-tacos (REQUERIDO si usas el monitor) ────────
DATOS_PATH=/ruta/a/bot-tacos/datos

# ── Facturama PAC (requerido solo para facturación CFDI) ─────────────────────
FACTURAMA_USER=TU_USUARIO_FACTURAMA
FACTURAMA_PASSWORD=TU_PASSWORD_FACTURAMA
FACTURAMA_SANDBOX=true

# ── Datos del emisor fiscal ───────────────────────────────────────────────────
EMISOR_RFC=XXXX000000XXX
EMISOR_NOMBRE=Tacos Aragón

# ── CFO Agent (contabilidad) ──────────────────────────────────────────────────
CFO_BASE=http://localhost:3002
CFO_TOKEN=TU_TOKEN_CFO_AQUI

# ── Rutas fiscales (opcional) ─────────────────────────────────────────────────
TAX_BOT_PATH=/ruta/a/tax-bot
FISCAL_PATH=/ruta/a/fiscal
